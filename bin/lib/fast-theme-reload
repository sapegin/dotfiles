#!/usr/bin/env zsh

# Recompile the fast-syntax-highlighting theme after sync-dotfiles updates the
# theme file.

theme="${1:-$HOME/dotfiles/colors/fast-syntax-highlighting-squirrelsong.ini}"
plugin="$(brew --prefix zsh-fast-syntax-highlighting 2>/dev/null)/share/zsh-fast-syntax-highlighting/fast-syntax-highlighting.plugin.zsh"

[[ -f $plugin ]] || exit 0
[[ -f $theme ]] || exit 0

source "$plugin"
fast-theme -q "$theme"
