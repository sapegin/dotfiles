#!/usr/bin/env node

// Finds images with 'VSCOcam' in their caption in the mobile photo backup.
//
// ---
// Author: Artem Sapegin, sapegin.me
// License: MIT
// https://github.com/sapegin/dotfiles

import fs from 'node:fs/promises';
import { execFileSync } from 'node:child_process';

const BASE_DIR = '/Volumes/Photos/Mobile';

async function main() {
	const files = await Array.fromAsync(
		fs.glob('*/Backup/*.*', { cwd: BASE_DIR })
	);

	console.error(`Scanning ${files.length} files…`);

	for (const file of files) {
		const filePath = `${BASE_DIR}/${file}`;
		try {
			const result = execFileSync(
				'exiftool',
				['-j', '-Caption-Abstract', '-ImageDescription', filePath],
				{ encoding: 'utf-8' }
			);
			const [data] = JSON.parse(result);
			const caption =
				(data['Caption-Abstract'] ?? '') + (data.ImageDescription ?? '');
			if (caption.toLowerCase().includes('vscocam')) {
				console.log(filePath);
			}
		} catch {
			// Skip files exiftool can't read
		}
	}
}

main().catch(console.error);
