#!/usr/bin/env node

// Backs up Obsidian config files, templates, and bases.
//
// ---
// Author: Artem Sapegin, sapegin.me
// License: MIT
// https://github.com/sapegin/dotfiles

import path from 'node:path';
import fs from 'node:fs/promises';
import os from 'node:os';

const untildify = (x) => x.replace(/^~/, os.homedir());

const DEST_DIR = path.join(import.meta.dirname, '/../obsidian');
const EXCLUDED_PATHS = [
  /^workspace.*?\.json/i,
  /\.obsidian\/plugins/i,
  /\.obsidian\/themes/i,
];
const DIRS_TO_BACKUP = [
	path.join('~/murder/.obsidian'),
	path.join('~/murder/templates'),
	path.join('~/murder/bases'),
];

async function copyFile(source, dest) {
	await fs.mkdir(path.dirname(dest), { recursive: true });
	await fs.copyFile(source, dest);
}

async function copyDirectory(source, dest) {
	const entries = await fs.readdir(source, { withFileTypes: true });

	for (const entry of entries) {
		const sourcePath = path.join(source, entry.name);
		const destPath = path.join(dest, entry.name);

    if (EXCLUDED_PATHS.some((regexp) => regexp.test(entry.name)) || EXCLUDED_PATHS.some((regexp) => regexp.test(entry.parentPath))) {
      console.log('Skipping', entry.name);
      continue;
    }

		if (entry.isDirectory()) {
			await copyDirectory(sourcePath, destPath);
		} else if (entry.isFile()) {

			await copyFile(sourcePath, destPath);
		}
	}
}

console.log();
console.log('Backing up Obsidian configs… 🧠');

try {
	// Delete the existing backup
	await fs.rm(DEST_DIR, { recursive: true, force: true });

	// Copy all the folders
	for (const from of DIRS_TO_BACKUP) {
		console.log('👉', from);
		const to = path.join(DEST_DIR, path.basename(from));
		await copyDirectory(untildify(from), to);
	}

	console.log();
	console.log('Done 🦜');
} catch (error) {
	console.error();
	console.error('Error:', error.message);
	process.exit(1);
}
