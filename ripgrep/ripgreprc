# Ignore case, unless the pattern includes capital letters
--smart-case

# Include hidden files (good for .eslinrc kind of files)
--hidden

# Don't let ripgrep vomit really long lines to my terminal, and show a preview.
--max-columns=150
--max-columns-preview

# Ignore npm/Yarn lock files, etc.
--glob=!package-lock.json
--glob=!yarn.lock
--glob=!.git

# Hide : after line numbers
--field-match-separator=

# Color theme
--colors=match:none
--colors=match:fg:red
--colors=match:style:intense
--colors=match:style:nobold
--colors=path:fg:blue
--colors=path:style:bold
--colors=line:none
--colors=line:fg:black
