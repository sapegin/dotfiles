// Sync configuration for bin/lib/sync-dotfiles.ts.
//
// Each entry links or syncs `source` to `destination`:
// - `mode: "link"` (default) creates a symlink at `destination`.
// - `mode: "sync"` two-way syncs `source` and `destination` by mtime: the newer
//   side overwrites the other; identical files are skipped.
//
// - Paths may start with `~/` to refer to the home directory.
// - When `source` contains `*` it is treated as a glob pattern: each match is
//   placed under `destination` using the match's basename.
// - `ignoreFolders: true` skips directory matches (glob sources only).
[
  // ~/dotfiles/tilde/.* → ~/
  {
    "source": "~/dotfiles/tilde/.*",
    "destination": "~",
    "ignoreFolders": true
  },
  // Homebrew bundle file
  {
    "source": "~/dotfiles/tilde/Brewfile",
    "destination": "~/Brewfile"
  },
  // ~/dotfiles/tilde/.config/* → ~/.config/
  {
    "source": "~/dotfiles/tilde/.config/*",
    "destination": "~/.config"
  },

  // Convenience symlink: iCloud Documents
  {
    "source": "~/Library/Mobile Documents/com~apple~CloudDocs",
    "destination": "~/cloud"
  },
  // Convenience symlink: Obsidian vault
  {
    "source": "~/Library/Mobile Documents/iCloud~md~obsidian/Documents/Murder",
    "destination": "~/murder"
  },
  // Visual Studio Code configs
  {
    "source": "~/dotfiles/vscode/User",
    "destination": "~/Library/Application Support/Code/User"
  },
  // Codex config
  {
    "source": "~/dotfiles/tilde/.codex/config.toml",
    "destination": "~/.codex/config.toml"
  },
  // Codex base prompt
  {
    "source": "~/dotfiles/ai-rules/AGENTS.md",
    "destination": "~/.codex/AGENTS.md"
  },
  // Codex skills
  {
    "source": "~/dotfiles/ai-rules/skills/*",
    "destination": "~/.codex/skills"
  },
  // Amp skills
  {
    "source": "~/dotfiles/ai-rules/skills/*",
    "destination": "~/.config/agents/skills"
  },
  // Copilot base prompt
  {
    "source": "~/dotfiles/ai-rules/AGENTS.md",
    "destination": "~/.copilot/instructions/base.instructions.md"
  },
  // Pi config
  {
    "source": "~/dotfiles/tilde/.pi/agent/settings.json",
    "destination": "~/.pi/agent/settings.json"
  },
  // Pi keybindings
  {
    "source": "~/dotfiles/tilde/.pi/agent/keybindings.json",
    "destination": "~/.pi/agent/keybindings.json"
  },
  // Pi base prompt
  {
    "source": "~/dotfiles/ai-rules/AGENTS.md",
    "destination": "~/.pi/agent/AGENTS.md"
  },
  // Pi Cmux notifications extension
  {
    "source": "~/dotfiles/tilde/.pi/agent/extensions/cmux-notifications.ts",
    "destination": "~/.pi/agent/extensions/cmux-notifications.ts"
  },
  // Pi Pretty extension
  {
    "source": "~/dotfiles/tilde/.pi/agent/extensions/pretty",
    "destination": "~/.pi/agent/extensions/pretty"
  },
  // Pi Permission System extension config
  {
    "source": "~/dotfiles/tilde/.pi/agent/extensions/pi-permission-system/config.json",
    "destination": "~/.pi/agent/extensions/pi-permission-system/config.json"
  },
  // Photoshop
  {
    "source": "~/Library/Mobile Documents/com~apple~CloudDocs/Apps/Adobe Photoshop 2024 Settings",
    "destination": "~/Library/Preferences/Adobe Photoshop 2024 Settings"
  }
]
