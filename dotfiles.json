// Sync configuration for sync-dotfiles.ts.
//
// Each entry links or syncs `source` to `destination`:
// - `mode: "link"` (default) creates a symlink at `destination`.
// - `mode: "sync"` two-way syncs `source` and `destination` by mtime: the newer
//   side overwrites the other; identical files are skipped.
//
// - Paths may start with `~/` to refer to the home directory.
// - `$DOTFILES_DIR` and `$THEMES_DIR` expand to those env vars (defaults:
//   ~/dotfiles and ~/_/squirrelsong/themes).
// - When `source` contains `*` it is treated as a glob pattern: each match is
//   placed under `destination` using the match's basename.
// - When `source` ends with `/` it is treated as a folder: the contents of
//   `source` and `destination` are two-way synced recursively. Requires
//   `mode: "sync"`; entries with other modes are skipped with a warning.
// - `ignore` is an array of JavaScript regex sources (substring match,
//   unanchored unless the pattern uses `^`/`$`). When the entry is a
//   directory the path is tested with a trailing `/`, so `/$` matches any
//   directory. `\.DS_Store$` is always ignored.
// - `runAfter` is an optional shell command to run after the entry has synced.
[
  /**
   * Basic dotfiles
   */

  // $DOTFILES_DIR/tilde/.* → ~/
  {
    "source": "$DOTFILES_DIR/tilde/.*",
    "destination": "~",
    "ignore": ["/$"] // All folders
  },
  // Homebrew bundle file
  {
    "source": "$DOTFILES_DIR/tilde/Brewfile",
    "destination": "~/Brewfile"
  },
  // $DOTFILES_DIR/tilde/.config/* → ~/.config/
  {
    "source": "$DOTFILES_DIR/tilde/.config/*",
    "destination": "~/.config"
  },

  /**
   * App configs
   */

  // Visual Studio Code configs
  {
    "source": "$DOTFILES_DIR/vscode/User",
    "destination": "~/Library/Application Support/Code/User"
  },
  // Supacode config
  {
    "source": "$DOTFILES_DIR/supacode/settings.json",
    "destination": "~/.supacode/"
  },
  // Photoshop
  {
    "source": "~/Library/Mobile Documents/com~apple~CloudDocs/Apps/Adobe Photoshop 2024 Settings",
    "destination": "~/Library/Preferences/Adobe Photoshop 2024 Settings"
  },

  /**
   * AI agents
   */

  // Skills (used by Pi, Cursor)
  {
    "source": "$DOTFILES_DIR/ai/skills/*",
    "destination": "~/.agents/skills/"
  },
  // Pi configs
  {
    "source": "$DOTFILES_DIR/pi/agent/*",
    "destination": "~/.pi/agent/",
    "ignore": ["^extensions"]
  },
  // Pi base prompt
  {
    "source": "$DOTFILES_DIR/ai/AGENTS.md",
    "destination": "~/.pi/agent/AGENTS.md"
  },
  // Pi custom extensions
  {
    "source": "$DOTFILES_DIR/pi/agent/extensions/*.ts",
    "destination": "~/.pi/agent/extensions/",
    "ignore": ["\\.test\\.ts$"]
  },

  /**
   * Obsidian (iCloud vault — sync copies only, never symlinks)
   */

  // Convenience symlink: Obsidian vault
  {
    "source": "~/Library/Mobile Documents/iCloud~md~obsidian/Documents/Murder",
    "destination": "~/murder"
  },
  // Folder Emoji Icon plugin config
  {
    "source": "$DOTFILES_DIR/obsidian/folder-icons.json",
    "destination": "~/murder/.obsidian/plugins/obsidian-folder-emoji-icons/data.json",
    "mode": "sync"
  },
  // Obsidian config backup (plugins and themes are synced separately)
  {
    "source": "~/murder/.obsidian/",
    "destination": "$DOTFILES_DIR/obsidian/.obsidian",
    "mode": "sync",
    "ignore": ["^workspace.*\\.json", "^plugins/", "^themes/"]
  },
  // Obsidian templates backup
  {
    "source": "~/murder/zz-templates/",
    "destination": "$DOTFILES_DIR/obsidian/zz-templates",
    "mode": "sync"
  },
  // Obsidian bases backup
  {
    "source": "~/murder/zz-bases/",
    "destination": "$DOTFILES_DIR/obsidian/zz-bases",
    "mode": "sync"
  },
  // Squirrelsong Obsidian theme
  {
    "source": "$THEMES_DIR/Obsidian/Squirrelsong/*",
    "destination": "~/murder/.obsidian/themes/Squirrelsong/",
    "mode": "sync"
  },
  // Handbook shared assets (source of truth in dotfiles)
  {
    "source": "$THEMES_DIR/CSS/squirrelsong.css",
    "destination": "$DOTFILES_DIR/pretty-html/_assets/squirrelsong.css",
    "mode": "sync"
  },
  {
    "source": "$DOTFILES_DIR/pretty-html/_assets/",
    "destination": "~/murder/zz-handbook/_assets/",
    "mode": "sync"
  },

  /**
   * Squirrelsong color themes
   *
   * These apps only load themes from their config directories, so those stay
   * symlinked.
   */

  // Bat (themes live under tilde/.config/bat, symlinked to ~/.config/bat)
  {
    "source": "$THEMES_DIR/Sublime Text/Squirrelsong Light/Squirrelsong Light.tmTheme",
    "destination": "$DOTFILES_DIR/tilde/.config/bat/themes/Squirrelsong Light.tmTheme"
  },
  {
    "source": "$THEMES_DIR/Sublime Text/Squirrelsong Dark/Squirrelsong Dark.tmTheme",
    "destination": "$DOTFILES_DIR/tilde/.config/bat/themes/Squirrelsong Dark.tmTheme",
    "runAfter": "bat cache --build"
  },
  // Ghostty
  {
    "source": "$THEMES_DIR/Ghostty/Squirrelsong *",
    "destination": "$DOTFILES_DIR/tilde/.config/ghostty/themes/"
  },

  /**
   * Misc.
   */

  // Convenience symlink: iCloud Documents
  {
    "source": "~/Library/Mobile Documents/com~apple~CloudDocs",
    "destination": "~/cloud"
  }
]
