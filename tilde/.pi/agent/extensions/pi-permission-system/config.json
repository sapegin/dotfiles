{
  "permission": {
    "*": "allow",
    "bash": {
      "*": "ask",
      "bash --version": "allow",
      "cd * && pnpm exec *": "allow",
      "command -v *": "allow",
      "find *": "allow",
      "git branch *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git merge-base *": "allow",
      "git rev-parse *": "allow",
      "git status *": "allow",
      "head *": "allow",
      "ls *": "allow",
      "nl *": "allow",
      "pnpm exec *": "allow",
      "rm -rf *": "deny",
      "sudo *": "ask"
    },
    "read": {
      "*": "allow",
      "~/dotfiles/*": "allow"
    },
    "edit": {
      "*": "allow"
    },
    "skill": {
      "*": "ask",
      "grill-in-code": "allow",
      "grill-me": "allow",
      "librarian": "allow",
      "review-code": "allow",
      "write-pr-description": "allow"
    },
    "external_directory": {
      "*": "ask",
      "~/dotfiles/*": "allow",
      "/opt/homebrew/bin/bash": "allow"
    },
    "third_party_tool": "ask",
    "mcp": "deny"
  }
}
