{
  "permission": {
    "*": "allow",
    "bash": {
      "*": "ask",
      "bash --version": "allow",
      "cd * && pnpm exec *": "allow",
      "command -v *": "allow",
      "cmp *": "allow",
      "find *": "allow",
      "git branch *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git merge-base *": "allow",
      "git rev-parse *": "allow",
      "git status *": "allow",
      "head *": "allow",
      "ls *": "allow",
      "nl *": "allow",
      "stat *": "allow",
      "pnpm exec *": "allow",
      "rm -rf *": "deny",
      "trafilatura *": "allow",
      "ddgr *": "allow",
      "echo *": "allow",
      "sudo *": "ask"
    },
    "read": {
      "*": "allow",
      "~/dotfiles/*": "allow"
    },
    "edit": {
      "*": "allow"
    },
    "skill": {
      "*": "ask",
      "github": "allow",
      "grill-in-code": "allow",
      "grill-me": "allow",
      "librarian": "allow",
      "review-code": "allow",
      "web-fetch": "allow",
      "web-search": "allow",
      "write-pr-description": "allow"
    },
    "external_directory": {
      "*": "ask",
      "~/dotfiles/*": "allow",
      "~/Library/Application Support/fnm/node-versions/*/@earendil-works/pi-coding-agent/*": "allow",
      "/opt/homebrew/bin/bash": "allow"
    },
    "third_party_tool": "ask",
    "mcp": "deny"
  }
}
