font-family = Monolisa
font-size = 17

# Disable ligatures and configure font features
font-feature = calt
font-feature = -clig
font-feature = -liga
font-feature = zero
font-feature = ss01

theme = dark:Squirrelsong Dark Deep Purple,light:Squirrelsong Light
minimum-contrast = 1.1
macos-icon = custom-style
macos-icon-frame = beige
# Generate extended 256 color palette based on theme base palette
palette-generate = true
palette-harmonious = true
faint-opacity = 0.75

# Bar non-blinking cursor
adjust-cursor-thickness = 2
cursor-style = bar
cursor-style-blink = false
shell-integration-features = no-cursor

window-padding-x = 8
window-padding-y = 12,8

clipboard-trim-trailing-spaces = true
copy-on-select = clipboard

macos-titlebar-style = tabs

# Make cmd+enter work. By default, Ghostty doesn’t send Cmd keypresses to
# terminal programs
keybind = cmd+enter=csi:13;9u
