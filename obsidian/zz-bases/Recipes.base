# Recipes
filters:
  and:
    - file.folder == "Food"
    - file.tags.contains("recipes")
views:
  - type: cards
    name: Cards
    order:
      - file.name
      - status
    sort:
      - property: file.name
        direction: ASC
    image: note.image
    imageAspectRatio: 0.45
    cardSize: 230
