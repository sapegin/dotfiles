filters:
  and:
    - file.folder.startsWith("📆 Log")
    - file.tags.contains("food-inspiration")
views:
  - type: cards
    name: Cards
    order:
      - file.name
      - description
    sort:
      - property: file.name
        direction: DESC
    image: note.image
    imageAspectRatio: 0.45
    cardSize: 230
