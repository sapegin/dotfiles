{
  "permission": {
    "*": "allow",
    "bash": {
      "*": "ask",
      "sudo *": "ask",
      "rm -rf *": "deny",
      "bash --version": "allow",
      "cd * && eslint *": "allow",
      "cd * && pnpm exec *": "allow",
      "cd * && prettier *": "allow",
      "cd *": "allow",
      "cmp *": "allow",
      "command -v *": "allow",
      "ddgr *": "allow",
      "du *": "allow",
      "echo *": "allow",
      "eslint *": "allow",
      "exit *": "allow",
      "find *": "allow",
      "gh api *": "allow",
      "git branch *": "allow",
      "git checkout *": "allow",
      "git diff *": "allow",
      "git grep *": "allow",
      "git log *": "allow",
      "git merge-base *": "allow",
      "git rev-parse *": "allow",
      "git show *": "allow",
      "git status *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "ls *": "allow",
      "nl *": "allow",
      "npx tsc *": "allow",
      "npx oxfmt *": "allow",
      "npm view *": "allow",
      "pnpm exec *": "allow",
      "pnpm lint *": "allow",
      "pnpm outdated *": "allow",
      "pnpm test *": "allow",
      "pnpm view *": "allow",
      "pnpm why *": "allow",
      "prettier *": "allow",
      "readlink *": "allow",
      "rg *": "allow",
      "sort *": "allow",
      "stat *": "allow",
      "tail *": "allow",
      "timeout *": "allow",
      "trafilatura *": "allow",
      "true": "allow",
      "wc *": "allow"
    },
    "read": {
      "*": "allow",
      "~/dotfiles/*": "allow",
      "~/.agents/*": "allow"
    },
    "edit": {
      "*": "allow"
    },
    "skill": {
      "*": "ask",
      "github": "allow",
      "grill-in-code": "allow",
      "grill-me": "allow",
      "librarian": "allow",
      "review-code": "allow",
      "web-fetch": "allow",
      "web-search": "allow",
      "write-pr-description": "allow"
    },
    "external_directory": {
      "*": "ask",
      "~/dotfiles/*": "allow",
      "~/.agents/*": "allow"
    },
    "third_party_tool": "ask",
    "mcp": "deny"
  }
}
